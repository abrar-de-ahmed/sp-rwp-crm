# Database
DATABASE_URL=file:./db/custom.db

# Auth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# GitHub
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=sp-rwp-crm

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_ZONE_ID=your-zone-id

# Meta (Facebook + Instagram)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-page-access-token
META_VERIFY_TOKEN=sp-rwp-crm-meta-verify

# WhatsApp Cloud API (via Meta)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=sp-rwp-crm-whatsapp-verify
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@craftedminds.pk
